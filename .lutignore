*.vssscc
.builds
*.pidb
*.scc
sql/
*.Cache
ClientBin/
[Ss]tyle[Cc]op.*
~$*
*~
*.dbmdl
*.[Pp]ublish.xml
*.pfx
*.publishsettings

# Кэш и временные файлы
ipch/
