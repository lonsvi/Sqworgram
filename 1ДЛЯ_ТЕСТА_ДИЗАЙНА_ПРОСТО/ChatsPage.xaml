<Page x:Class="_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО.ChatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="ChatsPage" d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Resources>
        <!-- Конвертеры -->
        <local:AvatarUrlToImageSourceConverter x:Key="AvatarUrlConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:TextMessageToVisibilityConverter x:Key="TextMessageToVisibilityConverter"/>

        <!-- Liquid Glass approx: Animations for chat interface -->
        <Storyboard x:Key="ChatPanelSlideIn">
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="10,10,-20,10" To="10" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="ShimmerAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="(Border.Background).(Brush.Transform).(TranslateTransform.X)"
                From="-400" To="400" Duration="0:0:1.5" RepeatBehavior="Forever" />
        </Storyboard>

        <Storyboard x:Key="BlobAnimation1" x:Shared="False" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" From="1" To="1.2" Duration="0:0:25"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" From="1" To="1.2" Duration="0:0:25"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)" From="0" To="90" Duration="0:0:30"/>
        </Storyboard>
        <Storyboard x:Key="BlobAnimation2" x:Shared="False" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" From="1.2" To="1" Duration="0:0:35"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" From="1.2" To="1" Duration="0:0:35"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)" From="0" To="-70" Duration="0:0:40"/>
        </Storyboard>

        <!-- Liquid Glass Chat List Item Style -->
        <Style x:Key="ChatListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16" Padding="12" Margin="6,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource LiquidGlassPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LiquidGlassSecondaryBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColorBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Liquid Glass ScrollBar -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="6" Background="{StaticResource LiquidGlassBorderBrush}" x:Name="thumbBorder" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource LiquidGlassSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource LiquidGlassOverlayBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="Transparent" Margin="2,0,0,0">
                                    <Track Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Liquid Glass ComboBox for Translation -->
        <Style x:Key="LiquidGlassComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource LiquidGlassPrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LiquidGlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="false" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="20" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" StrokeThickness="1.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" TextBlock.Foreground="{TemplateBinding Foreground}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Style="{StaticResource LiquidGlassCard}" CornerRadius="16">
                                        <ScrollViewer Margin="8">
                                            <StackPanel IsItemsHost="True" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LiquidGlassPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranslateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource LiquidGlassPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <!-- Liquid Glass approx: Main content area with animated gradient blobs background -->
    <Grid Background="{DynamicResource PrimaryBackgroundColor}" ClipToBounds="True">
        <!-- Animated Background Blobs -->
        <Grid x:Name="BackgroundAnimationGrid">
            <Border x:Name="Blob1" Width="600" Height="600" CornerRadius="300" Opacity="0.6" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-250,-200,0,0" Background="{DynamicResource Blob1Brush}">
                <Border.Effect>
                    <BlurEffect Radius="200"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform CenterX="300" CenterY="300"/>
                        <RotateTransform CenterX="300" CenterY="300"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource BlobAnimation1}"/>
                    </EventTrigger>
                </Border.Triggers>
            </Border>

            <Border x:Name="Blob2" Width="700" Height="700" CornerRadius="350" Opacity="0.55" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-300,-250" Background="{DynamicResource Blob2Brush}">
                <Border.Effect>
                    <BlurEffect Radius="250"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform CenterX="350" CenterY="350"/>
                        <RotateTransform CenterX="350" CenterY="350"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource BlobAnimation2}"/>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Chat List (Liquid Glass Card) -->
            <Border 
                x:Name="LeftPanelBorder" 
                Grid.Column="0" 
                Style="{StaticResource LiquidGlassCard}"
                CornerRadius="0,28,28,0"
                Padding="12"
                Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search Box -->
                    <TextBox 
                        x:Name="SearchTextBox" 
                        Grid.Row="0"
                        Style="{StaticResource LiquidGlassTextBox}"
                        Text="Поиск" 
                        Foreground="{DynamicResource SecondaryTextColor}"
                        Padding="16,12"
                        Margin="0,0,0,12"
                        GotFocus="SearchTextBox_GotFocus" 
                        LostFocus="SearchTextBox_LostFocus" 
                        TextChanged="SearchTextBox_TextChanged"/>

                    <!-- Chat List -->
                    <ListBox 
                        x:Name="ChatListBox" 
                        Grid.Row="1" 
                        Background="Transparent" 
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource ChatListItemStyle}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectionChanged="ChatListBox_SelectionChanged"
                        MouseRightButtonUp="ChatListBox_MouseRightButtonUp">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Avatar -->
                                    <Grid Grid.Column="0" Width="48" Height="48">
                                        <Ellipse Fill="{DynamicResource HoverBackgroundColor}"/>
                                        <Image 
                                            Source="{Binding AvatarUrl, Converter={StaticResource AvatarUrlConverter}}" 
                                            Stretch="UniformToFill">
                                            <Image.Clip>
                                                <EllipseGeometry RadiusX="24" RadiusY="24" Center="24,24"/>
                                            </Image.Clip>
                                        </Image>
                                        <!-- Online Indicator (Liquid Glass) -->
                                        <Ellipse 
                                            Width="12" 
                                            Height="12" 
                                            Fill="LimeGreen" 
                                            HorizontalAlignment="Right" 
                                            VerticalAlignment="Bottom" 
                                            Stroke="{DynamicResource PrimaryBackgroundColor}" 
                                            StrokeThickness="2"
                                            Visibility="{Binding IsOnline, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                    
                                    <!-- User Info -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock 
                                            Text="{Binding Login}" 
                                            Foreground="{DynamicResource PrimaryTextColor}" 
                                            FontSize="14" 
                                            FontWeight="SemiBold"
                                            Margin="0,0,0,2"/>
                                        <TextBlock FontSize="12" Foreground="{DynamicResource SecondaryTextColor}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Оффлайн"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTyping}" Value="True">
                                                            <Setter Property="Text" Value="печатает..."/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentColorBrush}"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsTyping}" Value="False"/>
                                                                <Condition Binding="{Binding IsOnline}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Text" Value="В сети"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom Action Buttons -->
                    <StackPanel 
                        Grid.Row="2" 
                        Orientation="Horizontal" 
                        Margin="0,12,0,0">
                        <Button 
                            x:Name="SettingsButton" 
                            Style="{StaticResource LiquidGlassIconButton}" 
                            Width="40" 
                            Height="40"
                            Click="SettingsButton_Click"
                            ToolTip="Параметры">
                            <Path 
                                Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.23C14.38,2,14.17,1.84,13.92,1.84h-3.84 c-0.25,0-0.46,0.16-0.49,0.39l-0.34,2.55c-0.59,0.24-1.13,0.57-1.62,0.94l-2.39-0.96c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.82,11.68,4.82,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.34,2.55 c0.02,0.24,0.23,0.39,0.49,0.39h3.84c0.25,0,0.46-0.16,0.49-0.39l0.34-2.55c0.59-0.24,1.13-0.57,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" 
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                Stretch="Uniform" 
                                Width="20"/>
                        </Button>
                        <Button 
                            x:Name="FavoriteButton" 
                            Style="{StaticResource LiquidGlassIconButton}" 
                            Width="40" 
                            Height="40"
                            Click="ToggleFavoriteMode_Click"
                            ToolTip="Избранное">
                            <Path 
                                Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" 
                                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                Stretch="Uniform" 
                                Width="20"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel: Chat Area -->
            <Grid Grid.Column="1">
                <!-- Placeholder when no chat selected -->
                <Border 
                    x:Name="ChatPlaceholder" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                    <TextBlock 
                        Text="Выберите, кому хотели бы написать" 
                        Foreground="{DynamicResource SecondaryTextColor}" 
                        FontSize="16"/>
                </Border>

                <!-- Active Chat Area (Liquid Glass) -->
                <Grid 
                    x:Name="ChatArea" 
                    Visibility="Collapsed"
                    Margin="8,0,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource ChatPanelSlideIn}"/>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat Header (Liquid Glass Card) -->
                    <Border 
                        x:Name="ChatHeaderBorder" 
                        Grid.Row="0" 
                        Style="{StaticResource LiquidGlassCard}"
                        CornerRadius="20"
                        Padding="20,16"
                        Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock 
                                    Grid.Column="0" 
                                    x:Name="ChatHeader" 
                                    Foreground="{DynamicResource PrimaryTextColor}" 
                                    FontSize="16" 
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,4" 
                                    VerticalAlignment="Center"/>
                                <TextBlock 
                                    x:Name="TypingIndicator" 
                                    Foreground="{DynamicResource AccentColorBrush}" 
                                    FontStyle="Italic" 
                                    FontSize="12" 
                                    Visibility="Collapsed"/>
                            </StackPanel>
                            
                            <ComboBox 
                                Grid.Column="1" 
                                x:Name="TranslationDirectionComboBox" 
                                Style="{StaticResource LiquidGlassComboBox}" 
                                Width="140"
                                Padding="12,8">
                                <ComboBoxItem Content="EN → RU" IsSelected="True"/>
                                <ComboBoxItem Content="RU → EN"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Messages Area -->
                    <ScrollViewer 
                        x:Name="ChatScrollViewer" 
                        Grid.Row="1" 
                        VerticalScrollBarVisibility="Auto" 
                        HorizontalScrollBarVisibility="Disabled"
                        Margin="0,0,0,8">
                        <ItemsControl 
                            x:Name="MessagesPanel" 
                            Margin="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:MessageViewModel}">
                                    <Grid Margin="0,4">
                                        <Grid.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ThicknessAnimation 
                                                            Storyboard.TargetName="MessageBubble" 
                                                            Storyboard.TargetProperty="Margin" 
                                                            From="0,20,0,0" 
                                                            To="8" 
                                                            Duration="0:0:0.4">
                                                            <ThicknessAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </ThicknessAnimation.EasingFunction>
                                                        </ThicknessAnimation>
                                                        <DoubleAnimation 
                                                            Storyboard.TargetName="MessageBubble" 
                                                            Storyboard.TargetProperty="Opacity" 
                                                            From="0" 
                                                            To="1" 
                                                            Duration="0:0:0.3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Grid.Triggers>
                                        
                                        <!-- Message Bubble (Liquid Glass) -->
                                        <Border 
                                            x:Name="MessageBubble" 
                                            Padding="14,10" 
                                            MaxWidth="420" 
                                            Opacity="0"
                                            CornerRadius="18">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource LiquidGlassPrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource LiquidGlassBorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSentByMe}" Value="True">
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="{DynamicResource BlobColor2Value}" Offset="0" />
                                                                        <GradientStop Color="{DynamicResource BlobColor1Value}" Offset="1" />
                                                                    </LinearGradientBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            <Setter Property="BorderBrush">
                                                                <Setter.Value>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                                                                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <!-- Attachment Image -->
                                                <!-- Spacing handled via Margin on child elements -->
                                                <Border 
                                                    CornerRadius="12" 
                                                    Margin="0,0,0,4" 
                                                    ClipToBounds="True">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" x:Name="shimmerBrush">
                                                            <GradientStop Color="#FF333333" Offset="0.0" />
                                                            <GradientStop Color="#FF4A4A4A" Offset="0.5" />
                                                            <GradientStop Color="#FF333333" Offset="1.0" />
                                                            <Brush.Transform>
                                                                <TranslateTransform X="-400" Y="0" />
                                                            </Brush.Transform>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard Storyboard="{StaticResource ShimmerAnimation}"/>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                    <Image 
                                                        Source="{Binding AttachmentUrl, Converter={StaticResource AvatarUrlConverter}}" 
                                                        MaxWidth="280" 
                                                        MaxHeight="280" 
                                                        Cursor="Hand" 
                                                        MouseLeftButtonDown="Image_MouseLeftButtonDown" 
                                                        Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AttachmentUrl, FallbackValue='', TargetNullValue=''}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                </Border>

                                                <!-- Message Text -->
                                                <TextBlock 
                                                    Text="{Binding MessageText}" 
                                                    TextWrapping="Wrap" 
                                                    FontSize="13"
                                                    Foreground="{DynamicResource PrimaryTextColor}"
                                                    Visibility="{Binding MessageText, Converter={StaticResource TextMessageToVisibilityConverter}}"/>

                                                <!-- Translate & Timestamp -->
                                                <Grid Margin="0,2,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button 
                                                        Grid.Column="0" 
                                                        Content="Перевести" 
                                                        Style="{StaticResource TranslateButtonStyle}"  
                                                        HorizontalAlignment="Left" 
                                                        Click="TranslateButton_Click" 
                                                        Tag="{Binding}" 
                                                        Visibility="{Binding MessageText, Converter={StaticResource TextMessageToVisibilityConverter}}"/>
                                                    <TextBlock 
                                                        x:Name="TimestampText" 
                                                        Grid.Column="1" 
                                                        Text="{Binding Timestamp, StringFormat='HH:mm'}" 
                                                        FontSize="11" 
                                                        HorizontalAlignment="Right"
                                                        Foreground="{DynamicResource SecondaryTextColor}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Message Input (Liquid Glass) -->
                    <Border 
                        x:Name="MessageInputPanelBorder" 
                        Grid.Row="2" 
                        Style="{StaticResource LiquidGlassCard}"
                        CornerRadius="24"
                        Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Attach File Button -->
                            <Button 
                                x:Name="AttachFileButton" 
                                Grid.Column="0" 
                                Style="{StaticResource LiquidGlassIconButton}" 
                                Width="40" 
                                Height="40"
                                Click="AttachFileButton_Click"
                                Padding="8"
                                ToolTip="Прикрепить файл">
                                <Path 
                                    Data="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                    Stretch="Uniform" 
                                    Width="18"/>
                            </Button>
                            
                            <!-- Message TextBox (Liquid Glass) -->
                            <TextBox 
                                x:Name="MessageTextBox" 
                                Grid.Column="1" 
                                Style="{StaticResource LiquidGlassTextBox}"
                                Margin="8,0"
                                Padding="12,8"
                                TextChanged="MessageTextBox_TextChanged" 
                                KeyDown="MessageTextBox_KeyDown"
                                AcceptsReturn="True"
                                VerticalScrollBarVisibility="Auto"/>
                            
                            <!-- Send Button -->
                            <Button 
                                x:Name="SendMessageButton" 
                                Grid.Column="2" 
                                Style="{StaticResource LiquidGlassIconButton}" 
                                Width="40" 
                                Height="40"
                                Click="SendMessage_Click"
                                Padding="8"
                                ToolTip="Отправить">
                                <Path 
                                    Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" 
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                                    Stretch="Uniform" 
                                    Width="18"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
