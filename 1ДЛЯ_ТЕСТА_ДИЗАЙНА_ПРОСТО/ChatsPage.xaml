<Page x:Class="_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО.ChatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="ChatsPage" d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Resources>
        <!-- Конвертеры -->
        <local:AvatarUrlToImageSourceConverter x:Key="AvatarUrlConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:TextMessageToVisibilityConverter x:Key="TextMessageToVisibilityConverter"/>

        <!-- ИЗМЕНЕНИЕ: Все локальные цвета и кисти удалены -->

        <!-- Анимации -->
        <Storyboard x:Key="ChatPanelSlideIn">
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="10,10,-20,10" To="10" Duration="0:0:0.3">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="ShimmerAnimation">
            <DoubleAnimation
                Storyboard.TargetProperty="(Border.Background).(Brush.Transform).(TranslateTransform.X)"
                From="-400" To="400" Duration="0:0:1.5" RepeatBehavior="Forever" />
        </Storyboard>

        <!-- Стили контролов (теперь используют динамические ресурсы) -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="18" BorderThickness="1" BorderBrush="Transparent">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBackgroundColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ControlBackgroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TranslateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColorBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="10" Margin="5,0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ControlBackgroundColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#33FFFFFF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource AccentColorValue}" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="4" Background="#668A9BAB" x:Name="thumbBorder" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#AA8A9BAB" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#DD8A9BAB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid>
                                    <Track Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="false" Background="{TemplateBinding Background}" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="20" />
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" TextBlock.Foreground="{TemplateBinding Foreground}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#DD1C1C1C" CornerRadius="5" BorderBrush="#33FFFFFF" BorderThickness="1">
                                        <ScrollViewer Margin="1">
                                            <StackPanel IsItemsHost="True" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBackgroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки удаления вложения -->
        <Style x:Key="RemoveAttachmentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FF0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Background="{DynamicResource PrimaryBackgroundColor}" ClipToBounds="True">
        <!-- Оптимизированный фон - градиент без анимаций -->
        <Grid x:Name="BackgroundAnimationGrid">
            <!-- Основной фоновый градиент (очень лёгкий) -->
            <Rectangle>
                <Rectangle.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#330A3A" Offset="0"/>
                        <GradientStop Color="#1A0B2E" Offset="0.5"/>
                        <GradientStop Color="#0F051A" Offset="1"/>
                    </RadialGradientBrush>
                </Rectangle.Fill>
                <Rectangle.CacheMode>
                    <BitmapCache EnableClearType="False" SnapsToDevicePixels="False"/>
                </Rectangle.CacheMode>
            </Rectangle>

            <!-- Дополнительный элемент для глубины (статичный, без blur) -->
            <Border Width="500" Height="500" CornerRadius="250" Opacity="0.15" 
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-200,-150,0,0" 
                    Background="{DynamicResource Blob1Brush}"
                    CacheMode="BitmapCache"/>

            <Border Width="600" Height="600" CornerRadius="300" Opacity="0.12" 
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-250,-200" 
                    Background="{DynamicResource Blob2Brush}"
                    CacheMode="BitmapCache"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель (Список чатов) -->
            <Border x:Name="LeftPanelBorder" Grid.Column="0" Background="{DynamicResource PanelBackgroundColor}" Margin="10" CornerRadius="20">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Чаты" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextColor}" Margin="5,0,0,15"/>

                    <TextBox x:Name="SearchTextBox" Grid.Row="1" Style="{StaticResource ModernTextBox}" Margin="0,0,0,10" 
                             GotFocus="SearchTextBox_GotFocus" LostFocus="SearchTextBox_LostFocus" TextChanged="SearchTextBox_TextChanged"/>

                    <ListBox x:Name="ChatListBox" 
         Grid.Row="2" 
         Background="Transparent" 
         BorderThickness="0" 
         ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
         SelectionChanged="ChatListBox_SelectionChanged" 
         MouseRightButtonUp="ChatListBox_MouseRightButtonUp"
         VirtualizingStackPanel.IsVirtualizing="True"
         Margin="5">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" 
                                CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="1" 
                                BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#22FFFFFF"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#11FFFFFF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#33FFFFFF"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#44FFFFFF"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MouseLeftButtonUp="ChatItem_MouseLeftButtonUp">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" 
                        BorderBrush="{DynamicResource AccentColorBrush}" BorderThickness="1.5">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding AvatarUrl, Converter={StaticResource AvatarUrlConverter}}" 
                                    Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Login}" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Foreground="White"/>

                                        <TextBlock FontSize="11" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Offline"/>
                                                    <Setter Property="Foreground" Value="#88FFFFFF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTyping}" Value="True">
                                                            <Setter Property="Text" Value="печатает..."/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentColorBrush}"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsTyping}" Value="False"/>
                                                                <Condition Binding="{Binding IsOnline}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Text" Value="Online"/>
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{DynamicResource AccentColorBrush}" 
                         Visibility="Collapsed" VerticalAlignment="Center" Margin="5"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="SettingsButton" Style="{StaticResource IconButton}" Click="SettingsButton_Click" Margin="5">
                            <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.81,11.69,4.81,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.5c-1.93,0-3.5-1.57-3.5-3.5 s1.57-3.5,3.5-3.5s3.5,1.57,3.5,3.5S13.93,15.5,12,15.5z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="20"/>
                        </Button>
                        <Button x:Name="ToggleFavoriteMode" Style="{StaticResource IconButton}" Click="ToggleFavoriteMode_Click" Margin="5">
                            <Path Data="M12,17.27L18.18,21l-1.64-7.03L22,9.24l-7.19-0.61L12,2L9.19,8.63L2,9.24l5.46,4.73L5.82,21L12,17.27z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="20"/>
                        </Button>
                        <Button x:Name="LogoutButton" Style="{StaticResource IconButton}" Click="LogoutButton_Click" Margin="5">
                            <Path Data="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="20"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Правая панель (Чат) -->
            <Grid Grid.Column="1">
                <TextBlock x:Name="NoChatSelectedTextBlock" Text="Выберите, кому хотели бы написать" Foreground="{DynamicResource SecondaryTextColor}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Grid x:Name="ChatArea" Visibility="Collapsed">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource ChatPanelSlideIn}"/>
                                    </Trigger.EnterActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="ChatHeaderBorder" Grid.Row="0" Background="#991C1C1C" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="10" Padding="15" Margin="10,10,10,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="SelectedChatLoginTextBlock" Text="Login" Foreground="{DynamicResource PrimaryTextColor}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" x:Name="TranslationDirectionComboBox" Style="{StaticResource ModernComboBoxStyle}" Width="120">
                                    <ComboBoxItem Content="EN → RU" IsSelected="True"/>
                                    <ComboBoxItem Content="RU → EN"/>
                                </ComboBox>
                            </Grid>
                            <TextBlock x:Name="TypingIndicator" Foreground="{DynamicResource AccentColorBrush}" FontStyle="Italic" FontSize="12" Margin="0,5,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="MessagesPanel" Margin="10,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:MessageViewModel}">
                                    <Grid>
                                        <Grid.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ThicknessAnimation Storyboard.TargetName="MessageBubble" Storyboard.TargetProperty="Margin" From="0,20,0,0" To="5" Duration="0:0:0.4">
                                                            <ThicknessAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </ThicknessAnimation.EasingFunction>
                                                        </ThicknessAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="MessageBubble" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Grid.Triggers>
                                        <Border x:Name="MessageBubble" Padding="12" MaxWidth="400" Opacity="0">
                                            <StackPanel>
                                                <Border CornerRadius="8" Margin="0,0,0,5" ClipToBounds="True">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FF333333" Offset="0.0" />
                                                            <GradientStop Color="#FF4A4A4A" Offset="0.5" />
                                                            <GradientStop Color="#FF333333" Offset="1.0" />
                                                            <Brush.Transform>
                                                                <TranslateTransform X="-400" Y="0" />
                                                            </Brush.Transform>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard Storyboard="{StaticResource ShimmerAnimation}"/>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                    <Image Source="{Binding AttachmentUrl, Converter={StaticResource AvatarUrlConverter}}" MaxWidth="250" MaxHeight="250" Cursor="Hand" MouseLeftButtonDown="Image_MouseLeftButtonDown" Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AttachmentUrl, FallbackValue='', TargetNullValue=''}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                        <Image.Triggers>
                                                            <EventTrigger RoutedEvent="Loaded">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Image.Triggers>
                                                    </Image>
                                                </Border>
                                                <TextBlock Text="{Binding MessageText}" TextWrapping="Wrap" FontSize="14" Visibility="{Binding MessageText, Converter={StaticResource TextMessageToVisibilityConverter}}"/>
                                                <Grid Margin="0,5,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="Перевести" Style="{StaticResource TranslateButtonStyle}" HorizontalAlignment="Left" Click="TranslateButton_Click" Tag="{Binding}" Visibility="{Binding MessageText, Converter={StaticResource TextMessageToVisibilityConverter}}"/>
                                                    <TextBlock x:Name="TimestampText" Grid.Column="1" Text="{Binding Timestamp, StringFormat='HH:mm'}" FontSize="10" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSentByMe}" Value="False">
                                            <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Left"/>
                                            <Setter TargetName="MessageBubble" Property="Background" Value="#991C1C1C"/>
                                            <Setter TargetName="MessageBubble" Property="BorderBrush" Value="#22FFFFFF"/>
                                            <Setter TargetName="MessageBubble" Property="BorderThickness" Value="1"/>
                                            <Setter TargetName="MessageBubble" Property="CornerRadius" Value="15,15,15,5"/>
                                            <Setter TargetName="MessageBubble" Property="TextBlock.Foreground" Value="{DynamicResource PrimaryTextColor}"/>
                                            <Setter TargetName="TimestampText" Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSentByMe}" Value="True">
                                            <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right"/>
                                            <Setter TargetName="MessageBubble" Property="CornerRadius" Value="15,15,5,15"/>
                                            <Setter TargetName="MessageBubble" Property="BorderBrush" Value="#33FFFFFF"/>
                                            <Setter TargetName="MessageBubble" Property="BorderThickness" Value="1"/>
                                            <Setter TargetName="MessageBubble" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{DynamicResource BlobColor2Value}" Offset="0" />
                                                        <GradientStop Color="{DynamicResource BlobColor1Value}" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="MessageBubble" Property="TextBlock.Foreground" Value="{DynamicResource PrimaryTextColor}"/>
                                            <Setter TargetName="TimestampText" Property="Foreground" Value="#D1D1D1"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border x:Name="MessageInputPanelBorder" 
        Grid.Row="2" 
        Background="#441C1C1C" 
        BorderBrush="#33FFFFFF" 
        BorderThickness="1.2" 
        CornerRadius="22" 
        Margin="12" 
        Padding="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.3" ShadowDepth="0"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="AttachmentPreviewContainer" 
                Grid.Row="0" 
                Visibility="Collapsed" 
                Background="#22FFFFFF" 
                CornerRadius="18"
                BorderBrush="#11FFFFFF" 
                BorderThickness="1"
                Padding="10" 
                Margin="8,8,8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Height="50" CornerRadius="12" ClipToBounds="True">
                                        <Image x:Name="AttachmentPreviewImage" Stretch="UniformToFill"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="AttachmentFileName" Text="Файл выбран" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="AttachmentFileSize" Foreground="#88FFFFFF" FontSize="10"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" x:Name="RemoveAttachmentButton" 
                        Click="RemoveAttachmentButton_Click"
                        Cursor="Hand"
                        Padding="8">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#AAFFFFFF"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <Path x:Name="PathIcon" 
                                                  Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" 
                                                  Fill="{TemplateBinding Foreground}" 
                                                  Stretch="Uniform" Width="14" Height="14"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="AttachFileButton" Grid.Column="0" Width="40" Height="40" Click="AttachFileButton_Click" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                                            <Path Data="M16.5,6V17.5A4,4 0 0,1 12.5,21.5A4,4 0 0,1 8.5,17.5V5A2.5,2.5 0 0,1 11,2.5A2.5,2.5 0 0,1 13.5,5V15.5A1,1 0 0,1 12.5,16.5A1,1 0 0,1 11.5,15.5V6H10V15.5A2.5,2.5 0 0,0 12.5,18A2.5,2.5 0 0,0 15,15.5V5A4,4 0 0,0 11,1A4,4 0 0,0 7,5V17.5A5.5,5.5 0 0,0 12.5,23A5.5,5.5 0 0,0 18,17.5V6H16.5Z" 
                                              Fill="White" Opacity="0.7" Stretch="Uniform" Width="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#22FFFFFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Border Grid.Column="1" Background="#22FFFFFF" CornerRadius="18" Margin="5,0">
                                    <TextBox x:Name="MessageTextBox" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         Foreground="White" 
                         CaretBrush="White"
                         Padding="12,10" 
                         FontSize="14" 
                         VerticalContentAlignment="Center"
                         TextChanged="MessageTextBox_TextChanged" 
                         KeyDown="MessageTextBox_KeyDown"/>
                                </Border>

                                <Button x:Name="SendMessageButton" Grid.Column="2" Width="42" Height="42" Click="SendMessageButton_Click" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="21">
                                                            <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Fill="White" Stretch="Uniform" Width="18" Height="18" Margin="3,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                                                <Setter TargetName="btnBorder" Property="Background" Value="#55FFFFFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Popup x:Name="FriendProfilePopup" IsOpen="False" AllowsTransparency="True" 
       PopupAnimation="Fade" Placement="Center" StaysOpen="False">

            <Border Background="#441C1C1C" 
            BorderBrush="#33FFFFFF" 
            BorderThickness="1.2" 
            CornerRadius="25" 
            Padding="20" 
            MinWidth="320">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.4" ShadowDepth="0"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="ProfileBackButton" 
                    Grid.Row="0"
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ProfileBackButton_Click"
                    Width="35" Height="35">
                        <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                      Fill="White" 
                      Stretch="Uniform" 
                      Width="18" Height="18"/>
                    </Button>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,5,0,10">

                        <Border Width="120" Height="120" CornerRadius="60" 
                        BorderBrush="{DynamicResource AccentColorBrush}" 
                        BorderThickness="3" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,20">
                            <Image x:Name="FriendAvatarImage" Stretch="UniformToFill">
                                <Image.Clip>
                                    <EllipseGeometry RadiusX="60" RadiusY="60" Center="60,60"/>
                                </Image.Clip>
                            </Image>
                        </Border>

                        <TextBlock x:Name="FriendLoginTextBlock" 
                           Text="Username" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           TextAlignment="Center" 
                           Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#FF4CAF50" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FriendStatusTextBlock" 
                               Text="Online" 
                               Foreground="#88FFFFFF" 
                               FontSize="13" 
                               TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Page>

