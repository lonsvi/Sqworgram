<Page x:Class="_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="LoginPage" d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Resources>
        <!-- Liquid Glass approx: Login form animations -->
        <Storyboard x:Key="LoginPanelFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,40,0,0" To="0" Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>

        <Storyboard x:Key="BlobAnimation1" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" From="1" To="1.2" Duration="0:0:25"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" From="1" To="1.2" Duration="0:0:25"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)" From="0" To="90" Duration="0:0:30"/>
        </Storyboard>
        <Storyboard x:Key="BlobAnimation2" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" From="1.2" To="1" Duration="0:0:35"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" From="1.2" To="1" Duration="0:0:35"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(RotateTransform.Angle)" From="0" To="-70" Duration="0:0:40"/>
        </Storyboard>
    </Page.Resources>

    <!-- Page Load Animations -->
    <Page.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="LoginPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.2">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="LoginPanel" Storyboard.TargetProperty="Margin" From="0,40,0,0" To="0" Duration="0:0:0.6">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <!-- Liquid Glass approx: Background with animated gradient blobs -->
    <Grid Background="{DynamicResource PrimaryBackgroundColor}" ClipToBounds="True">
        <!-- Animated Blob 1 - Top Left -->
        <Border 
            x:Name="Blob1" 
            Width="400" 
            Height="400" 
            CornerRadius="200" 
            Opacity="0.7" 
            HorizontalAlignment="Left" 
            VerticalAlignment="Top" 
            Margin="-150,-100,0,0"
            Background="{DynamicResource Blob1Brush}">
            <Border.Effect>
                <BlurEffect Radius="180"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform CenterX="200" CenterY="200"/>
                    <RotateTransform CenterX="200" CenterY="200"/>
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource BlobAnimation1}"/>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- Animated Blob 2 - Bottom Right -->
        <Border 
            x:Name="Blob2" 
            Width="500" 
            Height="500" 
            CornerRadius="250" 
            Opacity="0.5" 
            HorizontalAlignment="Right" 
            VerticalAlignment="Bottom" 
            Margin="0,0,-150,0"
            Background="{DynamicResource Blob2Brush}">
            <Border.Effect>
                <BlurEffect Radius="220"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform CenterX="250" CenterY="250"/>
                    <RotateTransform CenterX="250" CenterY="250"/>
                </TransformGroup>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource BlobAnimation2}"/>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- Login Panel (Liquid Glass Card) -->
        <Border
            x:Name="LoginPanel"
            Style="{StaticResource LiquidGlassCard}"
            Width="380"
            CornerRadius="32"
            Padding="32,40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0">
            <StackPanel VerticalAlignment="Center">
                <!-- Heading -->
                <TextBlock 
                    Text="Вход в мессенджер" 
                    Style="{StaticResource LiquidGlassHeading}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20"/>
                
                <TextBlock 
                    Text="Подключитесь к сообществу" 
                    Style="{StaticResource LiquidGlassCaption}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,24"/>

                <!-- Login Label -->
                <TextBlock 
                    Text="Логин" 
                    Style="{StaticResource LiquidGlassLabel}"
                    Margin="0,0,0,8"/>

                <!-- Login TextBox -->
                <TextBox 
                    x:Name="LoginTextBox" 
                    Style="{StaticResource LiquidGlassTextBox}"
                    Padding="16,12"
                    Margin="0,0,0,16"/>

                <!-- Password Label -->
                <TextBlock 
                    Text="Пароль" 
                    Style="{StaticResource LiquidGlassLabel}"
                    Margin="0,0,0,8"/>

                <!-- Password Box -->
                <PasswordBox 
                    x:Name="PasswordBox" 
                    Style="{StaticResource LiquidGlassPasswordBox}"
                    Padding="16,12"
                    Margin="0,0,0,24"/>

                <!-- Login Button -->
                <Button 
                    Content="Войти" 
                    Style="{StaticResource LiquidGlassPrimaryButton}"
                    Padding="20,14"
                    Margin="0,0,0,12"
                    Click="LoginButton_Click"
                    FontSize="15"/>

                <!-- Register Link -->
                <Button 
                    Content="Нет аккаунта? Зарегистрироваться" 
                    Style="{StaticResource LiquidGlassIconButton}"
                    HorizontalAlignment="Center"
                    Click="RegisterButton_Click"
                    Foreground="{DynamicResource AccentColorBrush}"
                    FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
