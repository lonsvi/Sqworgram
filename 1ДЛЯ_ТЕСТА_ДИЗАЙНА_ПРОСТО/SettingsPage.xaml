<Page x:Class="_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="SettingsPage" d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="SettingsTitle" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.1">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <!-- Liquid Glass approx: Settings panel -->
    <Grid Background="{DynamicResource PrimaryBackgroundColor}">
        <!-- Back Button -->
        <Button 
            x:Name="BackButton" 
            Style="{StaticResource LiquidGlassIconButton}" 
            HorizontalAlignment="Left" 
            VerticalAlignment="Top" 
            Margin="16,16,0,0" 
            Click="BackButton_Click" 
            Panel.ZIndex="1"
            Width="44"
            Height="44">
            <Path 
                Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" 
                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                Stretch="Uniform" 
                Width="20"/>
        </Button>

        <!-- Content ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center" MaxWidth="600" Margin="0,40,0,40">
                
                <!-- Title -->
                <TextBlock 
                    x:Name="SettingsTitle" 
                    Text="Настройки" 
                    Style="{StaticResource LiquidGlassHeading}"
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,32" 
                    Opacity="0"/>

                <!-- Profile Section -->
                <TextBlock 
                    Text="Профиль пользователя" 
                    Style="{StaticResource LiquidGlassHeading}"
                    Margin="0,0,0,16"/>

                <!-- Profile Card -->
                <Border 
                    Style="{StaticResource LiquidGlassCard}"
                    CornerRadius="28"
                    Padding="24"
                    Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Avatar Preview -->
                        <Border 
                            Width="100" 
                            Height="100" 
                            CornerRadius="50" 
                            BorderBrush="{StaticResource LiquidGlassBorderBrush}" 
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                            <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                        </Border>

                        <!-- Username -->
                        <TextBlock 
                            x:Name="UsernameText" 
                            Text="Имя пользователя" 
                            Style="{StaticResource LiquidGlassLabel}"
                            Margin="0,0,0,16"
                            HorizontalAlignment="Center"/>

                        <!-- Avatar URL Input Label -->
                        <TextBlock 
                            Text="URL аватара" 
                            Style="{StaticResource LiquidGlassLabel}"
                            Margin="0,0,0,8"/>
                        
                        <!-- Avatar URL TextBox -->
                        <TextBox 
                            x:Name="AvatarUrlTextBox" 
                            Style="{StaticResource LiquidGlassTextBox}" 
                            Padding="14,10"
                            Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Appearance Section -->
                <TextBlock 
                    Text="Оформление" 
                    Style="{StaticResource LiquidGlassHeading}"
                    Margin="0,0,0,16"/>

                <!-- Theme Settings -->
                <Border 
                    Style="{StaticResource LiquidGlassCard}"
                    CornerRadius="28"
                    Padding="24"
                    Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock 
                            Text="Выбор темы оформления" 
                            Style="{StaticResource LiquidGlassLabel}"
                            Margin="0,0,0,12"/>
                        
                        <Button 
                            Content="Настройки оформления →" 
                            Style="{StaticResource LiquidGlassPrimaryButton}"
                            Padding="16,12"
                            Click="ThemeSettingsButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Performance Section -->
                <TextBlock 
                    Text="Производительность" 
                    Style="{StaticResource LiquidGlassHeading}"
                    Margin="0,0,0,16"/>

                <!-- Settings Card -->
                <Border 
                    Style="{StaticResource LiquidGlassCard}"
                    CornerRadius="28"
                    Padding="24"
                    Margin="0,0,0,32">
                    <StackPanel>
                        <!-- Performance Settings Placeholder -->
                        <TextBlock 
                            Text="Параметры производительности приложения" 
                            Style="{StaticResource LiquidGlassCaption}"
                            Margin="0,0,0,20"/>

                        <!-- Logout Button -->
                        <Button 
                            Content="Выход" 
                            Style="{StaticResource LiquidGlassButton}"
                            Foreground="{DynamicResource AccentColorBrush}"
                            Padding="16,10"
                            Click="LogoutButton_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
