<Window x:Class="_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sqworogram"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        Width="1000" Height="600"
        MinWidth="800" MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent"
        Icon="/image (2).jpg"
        StateChanged="MainWindow_StateChanged">

    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#25FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome 
        ResizeBorderThickness="6" 
        CaptionHeight="38" 
        CornerRadius="0" 
        GlassFrameThickness="0" 
        UseAeroCaptionButtons="False" 
        NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border x:Name="MainWindowBorder" CornerRadius="12" BorderThickness="1" BorderBrush="#33FFFFFF" Background="#1A1A1A" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#05FFFFFF" BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" MouseDown="Border_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Border CornerRadius="4" ClipToBounds="True" Width="20" Height="20" Margin="0,0,10,0">
                            <Image Source="/image (2).jpg"/>
                        </Border>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                                   FontSize="12" FontWeight="SemiBold" Foreground="#FFDDDDDD" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0">
                        <Button Style="{StaticResource WindowControlButton}" Click="MinimizeButton_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Data="M0,8 H10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Stretch="Uniform" Width="10"/>
                        </Button>
                        <Button Style="{StaticResource WindowControlButton}" Click="MaximizeRestoreButton_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Data="M1,1 H9 V9 H1 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Stretch="Uniform" Width="10"/>
                        </Button>
                        <Button Style="{StaticResource CloseButton}" Click="CloseButton_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Data="M1,1 L9,9 M9,1 L1,9" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.2" Stretch="Uniform" Width="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

                <StackPanel x:Name="NotificationArea" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,15,15,0" Panel.ZIndex="100"/>
            </Grid>
        </Grid>
    </Border>
</Window>