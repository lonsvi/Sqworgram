<Page x:Class="_1ДЛЯ_ТЕСТА_ДИЗАЙНА_ПРОСТО.ThemeSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="ThemeSettingsPage" d:DesignHeight="600" d:DesignWidth="1000">

    <Page.Resources>
        <!-- Liquid Glass approx: Theme button animations -->
        <Storyboard x:Key="ThemePresetButtonHoverOn">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.18" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.18" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.5" Duration="0:0:0.2"/>
        </Storyboard>
        <Storyboard x:Key="ThemePresetButtonHoverOff">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.2" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- Theme Preset Button (Liquid Glass with rounded gradient) -->
        <Style x:Key="ThemePresetButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border 
                            x:Name="border" 
                            CornerRadius="28" 
                            Width="56" 
                            Height="56" 
                            BorderBrush="{StaticResource LiquidGlassBorderBrush}" 
                            BorderThickness="1.5">
                            <Border.Effect>
                                <DropShadowEffect 
                                    ShadowDepth="0" 
                                    Color="#000000" 
                                    BlurRadius="20" 
                                    Opacity="0.2"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" CenterX="28" CenterY="28"/>
                            </Border.RenderTransform>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource ThemePresetButtonHoverOn}"/>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource ThemePresetButtonHoverOff}"/>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- Page Load Animations -->
    <Page.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Title Animation -->
                    <DoubleAnimation Storyboard.TargetName="TitleText" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.1">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="TitleText" Storyboard.TargetProperty="Margin" From="0,60,0,30" To="0,40,0,30" Duration="0:0:0.5" BeginTime="0:0:0.1">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>

                    <!-- Presets Section Animation -->
                    <DoubleAnimation Storyboard.TargetName="PresetsTitle" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.25"/>
                    <DoubleAnimation Storyboard.TargetName="PresetsBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="PresetsBorder" Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5" BeginTime="0:0:0.35">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>

                    <!-- Custom Section Animation -->
                    <DoubleAnimation Storyboard.TargetName="CustomTitle" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="CustomBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <ThicknessAnimation Storyboard.TargetName="CustomBorder" Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0" Duration="0:0:0.5" BeginTime="0:0:0.6">
                        <ThicknessAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </ThicknessAnimation.EasingFunction>
                    </ThicknessAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>

    <!-- Liquid Glass approx: Theme customization page -->
    <Grid Background="{DynamicResource PrimaryBackgroundColor}">
        <!-- Back Button -->
        <Button 
            x:Name="BackButton" 
            Style="{StaticResource LiquidGlassIconButton}" 
            HorizontalAlignment="Left" 
            VerticalAlignment="Top" 
            Margin="16,16,0,0" 
            Click="BackButton_Click" 
            Panel.ZIndex="1"
            Width="44"
            Height="44">
            <Path 
                Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" 
                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" 
                Stretch="Uniform" 
                Width="20"/>
        </Button>

        <!-- Content Scroll Panel -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel HorizontalAlignment="Center" MaxWidth="520" Margin="0,40,0,40">
                
                <!-- Title -->
                <TextBlock 
                    x:Name="TitleText" 
                    Text="Настройка темы" 
                    Style="{StaticResource LiquidGlassHeading}"
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,40" 
                    Opacity="0"/>

                <!-- Preset Themes Section -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock 
                        x:Name="PresetsTitle" 
                        Text="Готовые темы" 
                        Style="{StaticResource LiquidGlassLabel}"
                        Margin="0,0,0,16"
                        Opacity="0"/>
                    
                    <!-- Preset Buttons Card (Liquid Glass) -->
                    <Border 
                        x:Name="PresetsBorder" 
                        Style="{StaticResource LiquidGlassCard}"
                        CornerRadius="28"
                        Padding="20"
                        Opacity="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Purple (Default) Preset -->
                            <Button 
                                Style="{StaticResource ThemePresetButtonStyle}" 
                                Tag="#FF6A359C;#FF4A00E0;#FF8E2DE2" 
                                Click="PresetButton_Click" 
                                ToolTip="Фиолетовая (по-умолчанию)"
                                Margin="0,0,16,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF6A359C" Offset="0"/>
                                        <GradientStop Color="#FF421061" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <!-- Ocean Preset -->
                            <Button 
                                Style="{StaticResource ThemePresetButtonStyle}" 
                                Tag="#FF0077be;#FF00529B;#FF00A4E4" 
                                Click="PresetButton_Click" 
                                ToolTip="Океан"
                                Margin="0,0,16,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF0077be" Offset="0"/>
                                        <GradientStop Color="#FF003D7A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <!-- Sunset Preset -->
                            <Button 
                                Style="{StaticResource ThemePresetButtonStyle}" 
                                Tag="#FFF47C3C;#FFFF5F6D;#FFFFC371" 
                                Click="PresetButton_Click" 
                                ToolTip="Закат"
                                Margin="0,0,16,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFF47C3C" Offset="0"/>
                                        <GradientStop Color="#FFFF5F6D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <!-- Forest Preset -->
                            <Button 
                                Style="{StaticResource ThemePresetButtonStyle}" 
                                Tag="#FF2E7D32;#FF1B5E20;#FF4CAF50" 
                                Click="PresetButton_Click" 
                                ToolTip="Лес">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF2E7D32" Offset="0"/>
                                        <GradientStop Color="#FF1B5E20" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Custom Theme Section -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock 
                        x:Name="CustomTitle" 
                        Text="Своя тема" 
                        Style="{StaticResource LiquidGlassLabel}"
                        Margin="0,0,0,16"
                        Opacity="0"/>
                    
                    <!-- Custom Color Picker Card (Liquid Glass) -->
                    <Border 
                        x:Name="CustomBorder" 
                        Style="{StaticResource LiquidGlassCard}"
                        CornerRadius="28"
                        Padding="24"
                        Opacity="0">
                        <StackPanel>
                            <!-- Accent Color -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock 
                                    Text="Цвет акцента" 
                                    Style="{StaticResource LiquidGlassLabel}"/>
                                <TextBlock 
                                    Text="Для выделений и основных элементов" 
                                    Style="{StaticResource LiquidGlassCaption}"
                                    Margin="0,4,0,0"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox 
                                        Grid.Column="0"
                                        x:Name="AccentColorTextBox" 
                                        Style="{StaticResource LiquidGlassTextBox}" 
                                        Padding="14,10"
                                        TextChanged="ColorTextBox_TextChanged"
                                        Margin="0,0,12,0"/>
                                    <Rectangle 
                                        Grid.Column="1"
                                        x:Name="AccentColorPreview" 
                                        RadiusX="12" 
                                        RadiusY="12" 
                                        Stroke="{StaticResource LiquidGlassBorderBrush}" 
                                        StrokeThickness="1.5"/>
                                </Grid>
                            </StackPanel>

                            <!-- Blob Color 1 -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock 
                                    Text="Фон №1 (верхний левый)" 
                                    Style="{StaticResource LiquidGlassLabel}"/>
                                <TextBlock 
                                    Text="Верхний левый градиент фона" 
                                    Style="{StaticResource LiquidGlassCaption}"
                                    Margin="0,4,0,0"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox 
                                        Grid.Column="0"
                                        x:Name="BlobColor1TextBox" 
                                        Style="{StaticResource LiquidGlassTextBox}" 
                                        Padding="14,10"
                                        TextChanged="ColorTextBox_TextChanged"
                                        Margin="0,0,12,0"/>
                                    <Rectangle 
                                        Grid.Column="1"
                                        x:Name="BlobColor1Preview" 
                                        RadiusX="12" 
                                        RadiusY="12" 
                                        Stroke="{StaticResource LiquidGlassBorderBrush}" 
                                        StrokeThickness="1.5"/>
                                </Grid>
                            </StackPanel>

                            <!-- Blob Color 2 -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock 
                                    Text="Фон №2 (нижний правый)" 
                                    Style="{StaticResource LiquidGlassLabel}"/>
                                <TextBlock 
                                    Text="Нижний правый градиент фона" 
                                    Style="{StaticResource LiquidGlassCaption}"
                                    Margin="0,4,0,0"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox 
                                        Grid.Column="0"
                                        x:Name="BlobColor2TextBox" 
                                        Style="{StaticResource LiquidGlassTextBox}" 
                                        Padding="14,10"
                                        TextChanged="ColorTextBox_TextChanged"
                                        Margin="0,0,12,0"/>
                                    <Rectangle 
                                        Grid.Column="1"
                                        x:Name="BlobColor2Preview" 
                                        RadiusX="12" 
                                        RadiusY="12" 
                                        Stroke="{StaticResource LiquidGlassBorderBrush}" 
                                        StrokeThickness="1.5"/>
                                </Grid>
                            </StackPanel>

                            <!-- Save Button -->
                            <Button 
                                Content="Сохранить свою тему" 
                                Style="{StaticResource LiquidGlassPrimaryButton}"
                                Padding="16,12" 
                                Margin="0,8,0,0"
                                Click="SaveCustomTheme_Click"
                                FontSize="14"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
